# DeepSeek Code Agent Desktop - 环境变量配置
# 复制为 .env 并填入你的配置值

# DeepSeek API Key（必须）
DEEPSEEK_API_KEY=sk-your-key-here

# Python 可执行文件路径（可选，默认使用系统 PATH 中的 python/python3）
DEEPSEEK_PYTHON_PATH=python3

# 后端源码路径（开发模式可选，默认在 ../deepseek-code-agent）
DEEPSEEK_AGENT_ROOT=

# 后端端口（可选，默认 8000）
DEEPSEEK_BACKEND_PORT=8000

# 调试模式（可选，输出详尽日志）
# DEBUG=true
