{
  "name": "deepseek-code-agent-desktop",
  "version": "1.1.0",
  "description": "DeepSeek Code Agent 桌面端 — Electron + React",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "eventsource": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.deepseek.codeagent.desktop",
    "productName": "DeepSeek Code Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "../deepseek-code-agent/src/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "resources/icon.ico",
      "sign": false
    },
    "publish": null,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  }
}
